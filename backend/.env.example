# ==============================================================================
# GREEN HERO BACKEND ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SUPABASE DATABASE CONFIGURATION (Required)
# ------------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-string
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-string

# Postgres connection string used for database migrations and CLI scripts
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ------------------------------------------------------------------------------
# 2. GOOGLE OAUTH CONFIGURATION
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-oauth-client-id-string.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-string

# ------------------------------------------------------------------------------
# 3. LLAMA COACH INTEGRATION CONFIGURATION
# ------------------------------------------------------------------------------
LLAMA_API_URL=https://api.llama-provider.com/v1
LLAMA_API_KEY=your-llama-api-key-token

# ------------------------------------------------------------------------------
# 4. FIREBASE SERVICES CONFIGURATION
# ------------------------------------------------------------------------------
FIREBASE_API_KEY=your-firebase-api-key-string
FIREBASE_PROJECT_ID=green-hero-firebase-project-id
FIREBASE_APP_ID=1:234567890:web:abcdef123456

# ------------------------------------------------------------------------------
# 5. GENERAL CONFIGURATION
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# ------------------------------------------------------------------------------
# 6. OBSERVABILITY & MONITORING CONFIGURATION
# ------------------------------------------------------------------------------
# Monitoring endpoints for Postgres metrics logging and error trace captures
DATABASE_LOG_LEVEL=info
DATABASE_MONITORING_TOKEN=your-db-telemetry-token
MONITORING_INGEST_URL=https://ingest.monitoring-provider.com

# ==============================================================================
# GREEN HERO FRONTEND ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. SUPABASE CONFIGURATION (Required)
# ------------------------------------------------------------------------------
# Retrieve these from your Supabase Dashboard -> Project Settings -> API
# NEXT_PUBLIC_ prefix makes them available in the browser client code
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-string

# ------------------------------------------------------------------------------
# 2. GOOGLE OAUTH CONFIGURATION
# ------------------------------------------------------------------------------
# Google OAuth client credentials for logging in via Google
GOOGLE_CLIENT_ID=your-google-oauth-client-id-string.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-string

# ------------------------------------------------------------------------------
# 3. LLAMA AI SUSTAINABILITY COACH CONFIGURATION
# ------------------------------------------------------------------------------
# Base API URL and access token. 
# NOTE: Kept strictly server-side (NO NEXT_PUBLIC_ prefix) to prevent secrets exposure.
LLAMA_API_URL=https://api.llama-provider.com/v1
LLAMA_API_KEY=your-llama-api-key-token

# ------------------------------------------------------------------------------
# 4. FIREBASE CLOUD SERVICES (Optional fallback)
# ------------------------------------------------------------------------------
# Optional fallback configurations for mobile pushes and telemetry
FIREBASE_API_KEY=your-firebase-api-key-string
FIREBASE_PROJECT_ID=green-hero-firebase-project-id
FIREBASE_APP_ID=1:234567890:web:abcdef123456

# ------------------------------------------------------------------------------
# 5. APP CONFIGURATION
# ------------------------------------------------------------------------------
# Base deployment URL used for OAuth callback redirection validation
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# ------------------------------------------------------------------------------
# 6. ANALYTICS & MONITORING CONFIGURATION
# ------------------------------------------------------------------------------
# Monitoring keys for tracking page load speeds, error logs, and token usage
# Set to true to enable Telemetry logs in server route handlers
NEXT_PUBLIC_TELEMETRY_ENABLED=false
ANALYTICS_WRITE_KEY=your-analytics-token
MONITORING_INGEST_URL=https://ingest.monitoring-provider.com

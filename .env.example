# ==============================================================================
# GREEN HERO FRONTEND ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. FIREBASE CONFIGURATION (Required)
# ------------------------------------------------------------------------------
# Retrieve these from your Firebase Console -> Project Settings -> General -> Your Apps
# Prefixing with NEXT_PUBLIC_ exposes them to the browser client code.
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key-string
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:234567890:web:abcdef123456

# ------------------------------------------------------------------------------
# 2. LLAMA AI SUSTAINABILITY COACH CONFIGURATION
# ------------------------------------------------------------------------------
# Base API URL and access token. 
# NOTE: Kept strictly server-side (NO NEXT_PUBLIC_ prefix) to prevent secrets exposure.
LLAMA_API_URL=https://api.llama-provider.com/v1
LLAMA_API_KEY=your-llama-api-key-token

# ------------------------------------------------------------------------------
# 3. APP CONFIGURATION
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development

# ------------------------------------------------------------------------------
# 4. ANALYTICS & MONITORING CONFIGURATION
# ------------------------------------------------------------------------------
# Monitoring keys for tracking page load speeds, error logs, and token usage
# Set to true to enable Telemetry logs in server route handlers
NEXT_PUBLIC_TELEMETRY_ENABLED=false
ANALYTICS_WRITE_KEY=your-analytics-token
MONITORING_INGEST_URL=https://ingest.monitoring-provider.com
